#!/usr/bin/env bash
set -euo pipefail

: "${CPLN_ORG:?CPLN_ORG environment variable is required}"
: "${REVIEW_APP_PREFIX:?REVIEW_APP_PREFIX environment variable is required}"

is_not_found() {
  grep -Eqi "does not exist|not found|404" <<< "$1"
}

secret_names="$(cpln secret query --org "$CPLN_ORG" --max 0 -o names)"

while IFS= read -r secret_name; do
  [[ -n "$secret_name" ]] || continue

  case "$secret_name" in
    "${REVIEW_APP_PREFIX}"-*-database)
      app_name="${secret_name%-database}"
      ;;
    *)
      continue
      ;;
  esac

  gvc_output=""
  if gvc_output="$(cpln gvc get "$app_name" --org "$CPLN_ORG" 2>&1)"; then
    continue
  fi

  if ! is_not_found "$gvc_output"; then
    echo "$gvc_output" >&2
    exit 1
  fi

  APP_NAME="$app_name" CPLN_ORG="$CPLN_ORG" script/control-plane/delete-shared-postgres-secret
done <<< "$secret_names"
