#!/usr/bin/env bash
set -euo pipefail

: "${APP_NAME:?APP_NAME environment variable is required}"
: "${CPLN_ORG:?CPLN_ORG environment variable is required}"

secret_name="${APP_NAME}-database"
policy_name="${secret_name}-policy"

is_not_found() {
  grep -Eqi "does not exist|not found|404" <<< "$1"
}

if [[ "${REQUIRE_APP_ABSENT:-true}" == "true" ]]; then
  gvc_output=""
  if gvc_output="$(cpln gvc get "$APP_NAME" --org "$CPLN_ORG" 2>&1)"; then
    echo "Review app ${APP_NAME} still exists; keeping shared Postgres database secret and policy." >&2
    exit 0
  fi

  if ! is_not_found "$gvc_output"; then
    echo "$gvc_output" >&2
    exit 1
  fi
fi

delete_if_exists() {
  local kind="$1"
  local name="$2"
  local get_output

  get_output=""
  if get_output="$(cpln "$kind" get "$name" --org "$CPLN_ORG" 2>&1)"; then
    cpln "$kind" delete "$name" --org "$CPLN_ORG" >/dev/null
    return
  fi

  if ! is_not_found "$get_output"; then
    echo "$get_output" >&2
    exit 1
  fi
}

delete_if_exists policy "$policy_name"
delete_if_exists secret "$secret_name"

echo "Shared Postgres database secret and policy are removed for ${APP_NAME}."
