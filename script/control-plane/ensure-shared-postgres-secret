#!/usr/bin/env bash
set -euo pipefail

: "${APP_NAME:?APP_NAME environment variable is required}"
: "${CPLN_ORG:?CPLN_ORG environment variable is required}"

postgres_url_prefix="${SHARED_POSTGRES_URL_PREFIX:-}"
source_secret_name="${SHARED_POSTGRES_SOURCE_SECRET:-}"
secret_name="${APP_NAME}-database"
policy_name="${secret_name}-policy"
review_app_prefix="${REVIEW_APP_PREFIX:-react-on-rails-hn-rsc-demo-review-pr}"

if [[ -z "$postgres_url_prefix" ]]; then
  if [[ -z "$source_secret_name" ]]; then
    echo "Set SHARED_POSTGRES_URL_PREFIX or SHARED_POSTGRES_SOURCE_SECRET." >&2
    exit 1
  fi

  postgres_url_prefix="$(
    cpln secret reveal "$source_secret_name" --org "$CPLN_ORG" -o json |
      ruby -rjson -ruri -e '
        secret = JSON.parse(STDIN.read)
        data = secret.fetch("data")
        url = data.fetch("DATABASE_URL")
        url = url.fetch("value") if url.is_a?(Hash) && url.key?("value")

        begin
          uri = URI(url)
          uri.path = ""
          uri.query = nil
          uri.fragment = nil
          print uri.to_s.sub(%r{/+\z}, "")
        rescue URI::InvalidURIError
          print url.sub(%r{/[^/?#]*(?:[?#].*)?\z}, "")
        end
      '
  )"
fi

postgres_url_prefix="${postgres_url_prefix%/}"

if [[ "${APP_NAME}" == "${review_app_prefix}"-* ]]; then
  default_runtime_secret_name="${review_app_prefix}-secrets"
else
  default_runtime_secret_name="${APP_NAME}-secrets"
fi

runtime_secret_name="${APP_RUNTIME_SECRETS_NAME:-$default_runtime_secret_name}"
runtime_policy_name="${APP_RUNTIME_SECRETS_POLICY_NAME:-${runtime_secret_name}-policy}"
identity_name="${APP_NAME}-identity"
identity_link="/org/${CPLN_ORG}/gvc/${APP_NAME}/identity/${APP_NAME}-identity"
app_workloads="${APP_WORKLOADS:-rails worker renderer}"

secret_file="$(mktemp)"
policy_file="$(mktemp)"
trap 'rm -f "$secret_file" "$policy_file"' EXIT

export DB_SECRET_NAME="$secret_name"
export DB_POLICY_NAME="$policy_name"
export APP_IDENTITY_LINK="$identity_link"
export SHARED_POSTGRES_URL_PREFIX="$postgres_url_prefix"

if ! cpln identity get "$identity_name" --org "$CPLN_ORG" --gvc "$APP_NAME" >/dev/null 2>&1; then
  cpln identity create --name "$identity_name" --org "$CPLN_ORG" --gvc "$APP_NAME" >/dev/null
fi

for workload_name in $app_workloads; do
  if cpln workload get "$workload_name" --org "$CPLN_ORG" --gvc "$APP_NAME" >/dev/null 2>&1; then
    cpln workload update \
      "$workload_name" \
      --org "$CPLN_ORG" \
      --gvc "$APP_NAME" \
      --set "spec.identityLink=$identity_name" \
      >/dev/null
  fi
done

ruby <<'RUBY' > "$secret_file"
require "yaml"
require "uri"

app_name = ENV.fetch("APP_NAME")
secret_name = ENV.fetch("DB_SECRET_NAME")
postgres_url_prefix = ENV.fetch("SHARED_POSTGRES_URL_PREFIX").sub(%r{/+\z}, "")

def database_url(postgres_url_prefix, database_name)
  uri = URI(postgres_url_prefix)
  uri.path = "/#{database_name}"
  uri.to_s
rescue URI::InvalidURIError
  "#{postgres_url_prefix}/#{database_name}"
end

database_urls = {
  "DATABASE_URL" => database_url(postgres_url_prefix, app_name),
  "CACHE_DATABASE_URL" => database_url(postgres_url_prefix, "#{app_name}_cache"),
  "QUEUE_DATABASE_URL" => database_url(postgres_url_prefix, "#{app_name}_queue"),
  "CABLE_DATABASE_URL" => database_url(postgres_url_prefix, "#{app_name}_cable")
}

puts({
  "kind" => "secret",
  "name" => secret_name,
  "type" => "dictionary",
  "data" => database_urls
}.to_yaml)
RUBY

ruby <<'RUBY' > "$policy_file"
require "yaml"

secret_name = ENV.fetch("DB_SECRET_NAME")
policy_name = ENV.fetch("DB_POLICY_NAME")
identity_link = ENV.fetch("APP_IDENTITY_LINK")

puts({
  "kind" => "policy",
  "name" => policy_name,
  "targetKind" => "secret",
  "targetLinks" => ["//secret/#{secret_name}"],
  "bindings" => [
    {
      "permissions" => ["reveal"],
      "principalLinks" => [identity_link]
    }
  ]
}.to_yaml)
RUBY

cpln apply --org "$CPLN_ORG" --file "$secret_file" >/dev/null
cpln apply --org "$CPLN_ORG" --file "$policy_file" >/dev/null

if ! cpln policy get "$runtime_policy_name" --org "$CPLN_ORG" >/dev/null 2>&1; then
  cpln policy create \
    --name "$runtime_policy_name" \
    --target-kind secret \
    --resource "$runtime_secret_name" \
    --org "$CPLN_ORG" \
    >/dev/null
fi

if ! cpln policy get "$runtime_policy_name" --org "$CPLN_ORG" -o json |
  jq -e --arg identity_link "$identity_link" '
    (.bindings // [])
    | any(
        ((.principalLinks // []) | index($identity_link))
        and ((.permissions // []) | index("reveal"))
      )
  ' >/dev/null; then
  add_binding_output="$(
    cpln policy add-binding \
      "$runtime_policy_name" \
      --org "$CPLN_ORG" \
      --identity "$identity_link" \
      --permission reveal \
      2>&1
  )" || {
    if ! grep -qi "already" <<< "$add_binding_output"; then
      echo "$add_binding_output" >&2
      exit 1
    fi
  }
fi

if ! cpln policy get "$policy_name" --org "$CPLN_ORG" -o json |
  jq -e --arg identity_link "$identity_link" '
    (.bindings // [])
    | any(
        ((.principalLinks // []) | index($identity_link))
        and ((.permissions // []) | index("reveal"))
      )
  ' >/dev/null; then
  add_binding_output="$(
    cpln policy add-binding \
      "$policy_name" \
      --org "$CPLN_ORG" \
      --identity "$identity_link" \
      --permission reveal \
      2>&1
  )" || {
    if ! grep -qi "already" <<< "$add_binding_output"; then
      echo "$add_binding_output" >&2
      exit 1
    fi
  }
fi

echo "Shared Postgres database secret and runtime secret access are ready for ${APP_NAME}."
